# ─── TeslaMate (existing — must match your current TeslaMate config) ───
TM_ENCRYPTION_KEY=your_teslamate_encryption_key
TM_DB_USER=teslamate
TM_DB_PASS=your_teslamate_db_password
TM_DB_NAME=teslamate
TZ=Europe/Paris

# ─── TeslaHub ─────────────────────────────────────────────────
# Passwords for auto-created database users (choose strong ones)
TESLAHUB_READER_PASS=choose_a_strong_password_1
TESLAHUB_APP_PASS=choose_a_strong_password_2

# Admin login for TeslaHub web interface
TESLAHUB_ADMIN_USER=admin
TESLAHUB_ADMIN_PASSWORD=choose_a_strong_password_3

# Session duration in days (browser stays logged in)
TESLAHUB_SESSION_DAYS=30

# JWT signing secret (generate with: openssl rand -hex 32)
TESLAHUB_JWT_SECRET=generate_a_64_char_random_string_here

# Map tiles (default = OpenStreetMap, change for custom tile server)
# MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# IP restriction (optional — empty = allow all, CIDR or comma-separated)
# TESLAHUB_ALLOWED_IPS=192.168.1.0/24
